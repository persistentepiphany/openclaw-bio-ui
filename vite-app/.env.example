# BioSentinel Dashboard — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env!

# Mapbox (map rendering)
VITE_MAPBOX_TOKEN=your-mapbox-token

# Bio API (Railway backend)
VITE_BIO_API_URL=https://your-railway-app.up.railway.app

# Scraper API (Cloudflare tunnel)
VITE_SCRAPER_API_URL=https://your-tunnel.trycloudflare.com
VITE_SCRAPER_API_KEY=your-scraper-key

# Z.AI (chat assistant) — ideally proxy server-side
VITE_Z_AI_API_KEY=your-zai-key

# Flock.io (compute orchestration)
VITE_FLOCK_API_KEY=your-flock-key
