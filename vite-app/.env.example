# BioSentinel Dashboard — Environment Variables (v2)
# Copy to .env and fill in real values. NEVER commit .env!

# Mapbox (map rendering)
VITE_MAPBOX_TOKEN=your-mapbox-token

# V2 Bio API (Railway backend) — single unified API, no scraper tunnel needed
VITE_BIO_API_URL=https://divine-cat-v2-v2.up.railway.app

# Z.AI (chat assistant) — ideally proxy server-side
VITE_Z_AI_API_KEY=your-zai-key

# Flock.io (compute orchestration)
VITE_FLOCK_API_KEY=your-flock-key

# REMOVED — Cloudflare scraper tunnel retired; ingestion now in v2 API
# VITE_SCRAPER_API_URL=
# VITE_SCRAPER_API_KEY=
